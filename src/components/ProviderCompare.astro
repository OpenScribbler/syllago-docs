---
/**
 * ProviderCompare.astro — Interactive side-by-side provider comparison.
 *
 * Embeds all provider data at build time. Vanilla JS handles dropdown
 * selection and table rendering on the client. No framework needed.
 *
 * Props:
 *   maxSlots: number — max providers to compare (default 3)
 *   defaultSlugs: string[] — initial provider selection (default first 2)
 */
import { getCollection } from 'astro:content';

interface Props {
  maxSlots?: number;
  defaultSlugs?: string[];
}

const { maxSlots = 3, defaultSlugs } = Astro.props;

const providers = await getCollection('providers');
const sorted = providers
  .map(p => p.data)
  .sort((a, b) => a.name.localeCompare(b.name));

// Pick defaults: first two alphabetically if not specified.
const defaults = defaultSlugs ?? sorted.slice(0, 2).map(p => p.slug);

// Loadouts are intentionally excluded: they're a syllago-specific bundling
// concept, not an upstream provider content type, so they don't belong in a
// cross-provider comparison view.
const CONTENT_TYPES = ['rules', 'skills', 'agents', 'mcp', 'hooks', 'commands'];
const CT_DISPLAY: Record<string, string> = {
  rules: 'Rules', skills: 'Skills', agents: 'Agents',
  mcp: 'MCP Configs', hooks: 'Hooks', commands: 'Commands',
};
const FORMAT_DISPLAY: Record<string, string> = {
  md: 'Markdown', mdc: 'MDC', json: 'JSON', jsonc: 'JSONC', yaml: 'YAML', toml: 'TOML',
};
const METHOD_DISPLAY: Record<string, string> = {
  filesystem: 'Symlink', 'json-merge': 'JSON merge', 'project-scope': 'Project scope',
};
---

<div
  class="provider-compare"
  data-max-slots={maxSlots}
  data-defaults={JSON.stringify(defaults)}
  data-providers={JSON.stringify(sorted)}
>
  <div class="compare-controls">
    {defaults.map((slug, i) => (
      <select class="provider-select" data-slot={i} aria-label={`Provider ${i + 1}`}>
        <option value="">Select provider…</option>
        {sorted.map(p => (
          <option value={p.slug} selected={p.slug === slug}>{p.name}</option>
        ))}
      </select>
    ))}
    {defaults.length < maxSlots && (
      <button class="add-provider-btn" type="button" aria-label="Add another provider to compare">
        + Add
      </button>
    )}
  </div>

  <!-- Desktop view: side-by-side matrix. Hidden below 600px via CSS. -->
  <div class="compare-scroll-wrapper compare-desktop-view">
    <button class="scroll-indicator scroll-indicator-left" type="button" aria-label="Scroll left">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M12 4l-6 6 6 6"/>
      </svg>
    </button>
    <button class="scroll-indicator scroll-indicator-right" type="button" aria-label="Scroll right to see more">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M8 4l6 6-6 6"/>
      </svg>
    </button>
    <div class="compare-table-container">
      <table class="compare-table">
        <thead>
          <tr>
            <th class="row-label-col">Feature</th>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              return <th class="provider-col" data-slug={slug}>{prov?.name ?? slug}</th>;
            })}
          </tr>
        </thead>
        <tbody>
          {/* Overview section */}
          <tr class="section-header"><td colspan={defaults.length + 1}>General</td></tr>
          <tr>
            <td class="row-label">Config directory</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              return <td data-slug={slug}><code>~/{prov?.configDir}</code></td>;
            })}
          </tr>
          <tr>
            <td class="row-label">Emit path</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const emit = prov?.emitPath?.replace('{project}/', '') ?? '—';
              return <td data-slug={slug}>{emit !== '—' ? <code>{emit}</code> : '—'}</td>;
            })}
          </tr>

          {/* Content type support */}
          <tr class="section-header"><td colspan={defaults.length + 1}>Content Type Support</td></tr>
          {CONTENT_TYPES.map(ct => (
            <tr>
              <td class="row-label">{CT_DISPLAY[ct] ?? ct}</td>
              {defaults.map((slug) => {
                const prov = sorted.find(p => p.slug === slug);
                const cap = prov?.content?.[ct];
                if (!cap?.supported) return <td data-slug={slug} class="cell-no">—</td>;
                const fmt = FORMAT_DISPLAY[cap.fileFormat ?? ''] ?? cap.fileFormat ?? '';
                const method = METHOD_DISPLAY[cap.installMethod ?? ''] ?? cap.installMethod ?? '';
                const detail = [fmt, method].filter(Boolean).join(' · ');
                return <td data-slug={slug} class="cell-yes">{detail || 'Yes'}</td>;
              })}
            </tr>
          ))}

          {/* Hooks detail */}
          <tr class="section-header"><td colspan={defaults.length + 1}>Hooks</td></tr>
          <tr>
            <td class="row-label">Hook events</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const hooks = prov?.content?.hooks;
              if (!hooks?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              const count = hooks.hookEvents?.length ?? 0;
              return <td data-slug={slug}>{count > 0 ? `${count} events` : 'Pending'}</td>;
            })}
          </tr>
          <tr>
            <td class="row-label">Hook types</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const hooks = prov?.content?.hooks;
              if (!hooks?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              const types = hooks.hookTypes ?? ['command'];
              return <td data-slug={slug}>{types.map(t => <code>{t}</code>)}</td>;
            })}
          </tr>
          <tr>
            <td class="row-label">Hook config</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const hooks = prov?.content?.hooks;
              if (!hooks?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              return <td data-slug={slug}>{hooks.configLocation ? <code>{hooks.configLocation}</code> : '—'}</td>;
            })}
          </tr>

          {/* MCP detail */}
          <tr class="section-header"><td colspan={defaults.length + 1}>MCP</td></tr>
          <tr>
            <td class="row-label">Transports</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const mcp = prov?.content?.mcp;
              if (!mcp?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              const transports = mcp.mcpTransports ?? [];
              return <td data-slug={slug}>{transports.length > 0 ? transports.join(', ') : '—'}</td>;
            })}
          </tr>
          <tr>
            <td class="row-label">MCP config file</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const mcp = prov?.content?.mcp;
              if (!mcp?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              return <td data-slug={slug}>{mcp.configLocation ? <code>{mcp.configLocation}</code> : '—'}</td>;
            })}
          </tr>

          {/* Rules detail */}
          <tr class="section-header"><td colspan={defaults.length + 1}>Rules</td></tr>
          <tr>
            <td class="row-label">Format</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const rules = prov?.content?.rules;
              if (!rules?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              return <td data-slug={slug}>{FORMAT_DISPLAY[rules.fileFormat ?? ''] ?? rules.fileFormat ?? '—'}</td>;
            })}
          </tr>
          <tr>
            <td class="row-label">Frontmatter fields</td>
            {defaults.map((slug) => {
              const prov = sorted.find(p => p.slug === slug);
              const rules = prov?.content?.rules;
              if (!rules?.supported) return <td data-slug={slug} class="cell-no">—</td>;
              const fields = rules.frontmatterFields ?? [];
              return <td data-slug={slug}>{fields.length > 0 ? fields.map(f => <code>{f}</code>) : 'None'}</td>;
            })}
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile view: tab one provider at a time, vertical feature list. Hidden
       above 600px via CSS. Tabs and panel are built by the client script from
       the same selected-providers state the desktop matrix uses. -->
  <div class="compare-mobile-view">
    <div class="compare-tabs" role="tablist" aria-label="Selected providers"></div>
    <div class="compare-panel" role="tabpanel"></div>
  </div>
</div>

<!-- All styles are in src/styles/tables.css (global) so JS-created elements get styled -->

<script is:inline>
(function() {
  function init() {
    var root = document.querySelector('.provider-compare');
    if (!root || root.dataset.initialized) return;
    root.dataset.initialized = 'true';

    var allProviders = JSON.parse(root.dataset.providers);

    var maxSlots = parseInt(root.dataset.maxSlots) || 3;
    var selected = JSON.parse(root.dataset.defaults);

    var controls = root.querySelector('.compare-controls');
    var container = root.querySelector('.compare-table-container');
    var indicatorRight = root.querySelector('.scroll-indicator-right');
    var indicatorLeft = root.querySelector('.scroll-indicator-left');
    var tabsEl = root.querySelector('.compare-tabs');
    var panelEl = root.querySelector('.compare-panel');

    // Track which provider's card is visible in the mobile tabbed view.
    // Defaults to the first valid selection and is clamped inside renderMobile
    // whenever selected changes so it never points at a slot the user removed.
    var activeMobileSlug = selected[0];

    var CONTENT_TYPES = ['rules', 'skills', 'agents', 'mcp', 'hooks', 'commands'];
    var CT_DISPLAY = {
      rules: 'Rules', skills: 'Skills', agents: 'Agents',
      mcp: 'MCP Configs', hooks: 'Hooks', commands: 'Commands'
    };
    var SECTION_TITLES = {
      general: 'General',
      contentTypes: 'Content Type Support',
      hooks: 'Hooks',
      mcp: 'MCP',
      rules: 'Rules'
    };
    var FORMAT_DISPLAY = {
      md: 'Markdown', mdc: 'MDC', json: 'JSON', jsonc: 'JSONC', yaml: 'YAML', toml: 'TOML'
    };
    var METHOD_DISPLAY = {
      filesystem: 'Symlink', 'json-merge': 'JSON merge', 'project-scope': 'Project scope'
    };

    function getProvider(slug) {
      for (var i = 0; i < allProviders.length; i++) {
        if (allProviders[i].slug === slug) return allProviders[i];
      }
      return null;
    }

    // Safe DOM table builder — no innerHTML, builds elements directly.
    function createEl(tag, className, text) {
      var el = document.createElement(tag);
      if (className) el.className = className;
      if (text !== undefined) el.textContent = text;
      return el;
    }

    function createCode(text) {
      var c = document.createElement('code');
      c.textContent = text;
      return c;
    }

    function createCell(text, className) {
      var td = document.createElement('td');
      if (className) td.className = className;
      if (text !== undefined) td.textContent = text;
      return td;
    }

    function createCodeCell(text) {
      var td = document.createElement('td');
      td.appendChild(createCode(text));
      return td;
    }

    function createDashCell() {
      return createCell('—', 'cell-no');
    }

    function checkScroll() {
      if (!container) return;
      var hasOverflow = container.scrollWidth > container.clientWidth;
      var atEnd = container.scrollLeft + container.clientWidth >= container.scrollWidth - 2;
      var atStart = container.scrollLeft <= 2;
      if (indicatorRight) indicatorRight.classList.toggle('visible', hasOverflow && !atEnd);
      if (indicatorLeft) indicatorLeft.classList.toggle('visible', hasOverflow && !atStart);
    }

    function buildSectionHeader(text, cols) {
      var tr = document.createElement('tr');
      tr.className = 'section-header';
      var td = document.createElement('td');
      td.setAttribute('colspan', cols);
      td.textContent = text;
      tr.appendChild(td);
      return tr;
    }

    function buildRow(label, provs, cellFn) {
      var tr = document.createElement('tr');
      var labelTd = createCell(label, 'row-label');
      tr.appendChild(labelTd);
      provs.forEach(function(p) {
        tr.appendChild(cellFn(p));
      });
      return tr;
    }

    function render() {
      var provs = selected.map(getProvider).filter(Boolean);
      if (provs.length === 0) return;

      var cols = provs.length + 1;
      var table = root.querySelector('.compare-table');

      // Clear and rebuild table using DOM methods.
      while (table.firstChild) table.removeChild(table.firstChild);

      // Header
      var thead = document.createElement('thead');
      var headerRow = document.createElement('tr');
      headerRow.appendChild(createEl('th', 'row-label-col', 'Feature'));
      provs.forEach(function(p) {
        headerRow.appendChild(createEl('th', 'provider-col', p.name));
      });
      thead.appendChild(headerRow);
      table.appendChild(thead);

      var tbody = document.createElement('tbody');

      // General section
      tbody.appendChild(buildSectionHeader('General', cols));
      tbody.appendChild(buildRow('Config directory', provs, function(p) {
        return createCodeCell('~/' + p.configDir);
      }));
      tbody.appendChild(buildRow('Emit path', provs, function(p) {
        var emit = p.emitPath ? p.emitPath.replace('{project}/', '') : null;
        return emit ? createCodeCell(emit) : createCell('—');
      }));

      // Content type support
      tbody.appendChild(buildSectionHeader('Content Type Support', cols));
      CONTENT_TYPES.forEach(function(ct) {
        tbody.appendChild(buildRow(CT_DISPLAY[ct] || ct, provs, function(p) {
          var cap = p.content && p.content[ct];
          if (!cap || !cap.supported) return createDashCell();
          var fmt = FORMAT_DISPLAY[cap.fileFormat || ''] || cap.fileFormat || '';
          var method = METHOD_DISPLAY[cap.installMethod || ''] || cap.installMethod || '';
          var detail = [fmt, method].filter(Boolean).join(' \u00b7 ');
          return createCell(detail || 'Yes', 'cell-yes');
        }));
      });

      // Hooks
      tbody.appendChild(buildSectionHeader('Hooks', cols));
      tbody.appendChild(buildRow('Hook events', provs, function(p) {
        var h = p.content && p.content.hooks;
        if (!h || !h.supported) return createDashCell();
        var count = (h.hookEvents || []).length;
        return createCell(count > 0 ? count + ' events' : 'Pending');
      }));
      tbody.appendChild(buildRow('Hook types', provs, function(p) {
        var h = p.content && p.content.hooks;
        if (!h || !h.supported) return createDashCell();
        var td = document.createElement('td');
        (h.hookTypes || ['command']).forEach(function(t, i) {
          if (i > 0) td.appendChild(document.createTextNode(' '));
          td.appendChild(createCode(t));
        });
        return td;
      }));
      tbody.appendChild(buildRow('Hook config', provs, function(p) {
        var h = p.content && p.content.hooks;
        if (!h || !h.supported) return createDashCell();
        return h.configLocation ? createCodeCell(h.configLocation) : createCell('—');
      }));

      // MCP
      tbody.appendChild(buildSectionHeader('MCP', cols));
      tbody.appendChild(buildRow('Transports', provs, function(p) {
        var m = p.content && p.content.mcp;
        if (!m || !m.supported) return createDashCell();
        var t = m.mcpTransports || [];
        return createCell(t.length > 0 ? t.join(', ') : '—');
      }));
      tbody.appendChild(buildRow('MCP config file', provs, function(p) {
        var m = p.content && p.content.mcp;
        if (!m || !m.supported) return createDashCell();
        return m.configLocation ? createCodeCell(m.configLocation) : createCell('—');
      }));

      // Rules
      tbody.appendChild(buildSectionHeader('Rules', cols));
      tbody.appendChild(buildRow('Format', provs, function(p) {
        var r = p.content && p.content.rules;
        if (!r || !r.supported) return createDashCell();
        return createCell(FORMAT_DISPLAY[r.fileFormat || ''] || r.fileFormat || '—');
      }));
      tbody.appendChild(buildRow('Frontmatter fields', provs, function(p) {
        var r = p.content && p.content.rules;
        if (!r || !r.supported) return createDashCell();
        var fields = r.frontmatterFields || [];
        if (fields.length === 0) return createCell('None');
        var td = document.createElement('td');
        fields.forEach(function(f, i) {
          if (i > 0) td.appendChild(document.createTextNode(' '));
          td.appendChild(createCode(f));
        });
        return td;
      }));

      table.appendChild(tbody);

      requestAnimationFrame(checkScroll);
    }

    // Mobile view: render tabs for each selected provider and a vertical
    // feature list for whichever tab is currently active. Called alongside
    // render() — CSS media query decides which view is visible, so both
    // renderers always run after a state change.
    function buildDt(text) {
      var dt = document.createElement('dt');
      dt.textContent = text;
      return dt;
    }

    function buildDd(content) {
      var dd = document.createElement('dd');
      if (typeof content === 'string') dd.textContent = content;
      else if (content) dd.appendChild(content);
      return dd;
    }

    function buildCodeDd(text) {
      var dd = document.createElement('dd');
      dd.appendChild(createCode(text));
      return dd;
    }

    function buildSection(title) {
      var section = document.createElement('section');
      section.className = 'compare-mobile-section';
      var h = document.createElement('h3');
      h.textContent = title;
      section.appendChild(h);
      var dl = document.createElement('dl');
      section.appendChild(dl);
      return { section: section, dl: dl };
    }

    function renderMobile() {
      if (!tabsEl || !panelEl) return;

      // Clamp activeMobileSlug to the current selection. If the user removed
      // the previously active provider, fall back to the first selected slot.
      if (selected.indexOf(activeMobileSlug) === -1) {
        activeMobileSlug = selected[0];
      }

      // Rebuild tab strip.
      while (tabsEl.firstChild) tabsEl.removeChild(tabsEl.firstChild);
      selected.forEach(function(slug) {
        var prov = getProvider(slug);
        if (!prov) return;
        var tab = document.createElement('button');
        tab.type = 'button';
        tab.className = 'compare-tab';
        tab.setAttribute('role', 'tab');
        tab.dataset.slug = slug;
        tab.textContent = prov.name;
        if (slug === activeMobileSlug) {
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
        } else {
          tab.setAttribute('aria-selected', 'false');
        }
        tab.addEventListener('click', function() {
          activeMobileSlug = slug;
          renderMobile();
        });
        tabsEl.appendChild(tab);
      });

      // Rebuild panel for the active provider.
      while (panelEl.firstChild) panelEl.removeChild(panelEl.firstChild);
      var prov = getProvider(activeMobileSlug);
      if (!prov) return;

      // General
      var gen = buildSection(SECTION_TITLES.general);
      gen.dl.appendChild(buildDt('Config directory'));
      gen.dl.appendChild(buildCodeDd('~/' + prov.configDir));
      gen.dl.appendChild(buildDt('Emit path'));
      var emit = prov.emitPath ? prov.emitPath.replace('{project}/', '') : null;
      gen.dl.appendChild(emit ? buildCodeDd(emit) : buildDd('\u2014'));
      panelEl.appendChild(gen.section);

      // Content Type Support
      var cts = buildSection(SECTION_TITLES.contentTypes);
      CONTENT_TYPES.forEach(function(ct) {
        cts.dl.appendChild(buildDt(CT_DISPLAY[ct] || ct));
        var cap = prov.content && prov.content[ct];
        if (!cap || !cap.supported) {
          cts.dl.appendChild(buildDd('\u2014'));
          return;
        }
        var fmt = FORMAT_DISPLAY[cap.fileFormat || ''] || cap.fileFormat || '';
        var method = METHOD_DISPLAY[cap.installMethod || ''] || cap.installMethod || '';
        var detail = [fmt, method].filter(Boolean).join(' \u00b7 ');
        cts.dl.appendChild(buildDd(detail || 'Yes'));
      });
      panelEl.appendChild(cts.section);

      // Hooks
      var hooks = buildSection(SECTION_TITLES.hooks);
      var hcap = prov.content && prov.content.hooks;
      hooks.dl.appendChild(buildDt('Hook events'));
      if (!hcap || !hcap.supported) {
        hooks.dl.appendChild(buildDd('\u2014'));
      } else {
        var count = (hcap.hookEvents || []).length;
        hooks.dl.appendChild(buildDd(count > 0 ? count + ' events' : 'Pending'));
      }
      hooks.dl.appendChild(buildDt('Hook types'));
      if (!hcap || !hcap.supported) {
        hooks.dl.appendChild(buildDd('\u2014'));
      } else {
        var typeDd = document.createElement('dd');
        (hcap.hookTypes || ['command']).forEach(function(t, i) {
          if (i > 0) typeDd.appendChild(document.createTextNode(' '));
          typeDd.appendChild(createCode(t));
        });
        hooks.dl.appendChild(typeDd);
      }
      hooks.dl.appendChild(buildDt('Hook config'));
      if (!hcap || !hcap.supported) {
        hooks.dl.appendChild(buildDd('\u2014'));
      } else {
        hooks.dl.appendChild(hcap.configLocation ? buildCodeDd(hcap.configLocation) : buildDd('\u2014'));
      }
      panelEl.appendChild(hooks.section);

      // MCP
      var mcp = buildSection(SECTION_TITLES.mcp);
      var mcap = prov.content && prov.content.mcp;
      mcp.dl.appendChild(buildDt('Transports'));
      if (!mcap || !mcap.supported) {
        mcp.dl.appendChild(buildDd('\u2014'));
      } else {
        var transports = mcap.mcpTransports || [];
        mcp.dl.appendChild(buildDd(transports.length > 0 ? transports.join(', ') : '\u2014'));
      }
      mcp.dl.appendChild(buildDt('MCP config file'));
      if (!mcap || !mcap.supported) {
        mcp.dl.appendChild(buildDd('\u2014'));
      } else {
        mcp.dl.appendChild(mcap.configLocation ? buildCodeDd(mcap.configLocation) : buildDd('\u2014'));
      }
      panelEl.appendChild(mcp.section);

      // Rules
      var rules = buildSection(SECTION_TITLES.rules);
      var rcap = prov.content && prov.content.rules;
      rules.dl.appendChild(buildDt('Format'));
      if (!rcap || !rcap.supported) {
        rules.dl.appendChild(buildDd('\u2014'));
      } else {
        rules.dl.appendChild(buildDd(FORMAT_DISPLAY[rcap.fileFormat || ''] || rcap.fileFormat || '\u2014'));
      }
      rules.dl.appendChild(buildDt('Frontmatter fields'));
      if (!rcap || !rcap.supported) {
        rules.dl.appendChild(buildDd('\u2014'));
      } else {
        var fields = rcap.frontmatterFields || [];
        if (fields.length === 0) {
          rules.dl.appendChild(buildDd('None'));
        } else {
          var fieldDd = document.createElement('dd');
          fields.forEach(function(f, i) {
            if (i > 0) fieldDd.appendChild(document.createTextNode(' '));
            fieldDd.appendChild(createCode(f));
          });
          rules.dl.appendChild(fieldDd);
        }
      }
      panelEl.appendChild(rules.section);
    }

    // Single entry point so callers can't forget to update the mobile view.
    function renderAll() {
      render();
      renderMobile();
    }

    function updateControls() {
      while (controls.firstChild) controls.removeChild(controls.firstChild);

      selected.forEach(function(slug, i) {
        var sel = document.createElement('select');
        sel.className = 'provider-select';
        sel.dataset.slot = i;
        sel.setAttribute('aria-label', 'Provider ' + (i + 1));

        var emptyOpt = document.createElement('option');
        emptyOpt.value = '';
        emptyOpt.textContent = 'Select provider\u2026';
        sel.appendChild(emptyOpt);

        allProviders.forEach(function(p) {
          var opt = document.createElement('option');
          opt.value = p.slug;
          opt.textContent = p.name;
          if (p.slug === slug) opt.selected = true;
          sel.appendChild(opt);
        });

        sel.addEventListener('change', function() {
          selected[i] = sel.value;
          renderAll();
        });

        controls.appendChild(sel);
      });

      if (selected.length < maxSlots) {
        var btn = document.createElement('button');
        btn.className = 'add-provider-btn';
        btn.type = 'button';
        btn.textContent = '+ Add';
        btn.setAttribute('aria-label', 'Add another provider to compare');
        btn.addEventListener('click', function() {
          var used = {};
          selected.forEach(function(s) { used[s] = true; });
          var next = '';
          for (var j = 0; j < allProviders.length; j++) {
            if (!used[allProviders[j].slug]) { next = allProviders[j].slug; break; }
          }
          selected.push(next);
          updateControls();
          renderAll();
        });
        controls.appendChild(btn);
      }
    }

    // Scroll indicators — track scroll and make clickable
    if (container) {
      container.addEventListener('scroll', checkScroll);
      window.addEventListener('resize', checkScroll);
    }
    if (indicatorRight) {
      indicatorRight.addEventListener('click', function() {
        if (!container) return;
        container.scrollBy({ left: 200, behavior: 'smooth' });
      });
    }
    if (indicatorLeft) {
      indicatorLeft.addEventListener('click', function() {
        if (!container) return;
        container.scrollBy({ left: -200, behavior: 'smooth' });
      });
    }

    // Attach change handlers to SSR-rendered selects.
    var selects = controls.querySelectorAll('.provider-select');
    selects.forEach(function(sel) {
      sel.addEventListener('change', function() {
        var idx = parseInt(sel.dataset.slot);
        selected[idx] = sel.value;
        renderAll();
      });
    });

    var addBtn = controls.querySelector('.add-provider-btn');
    if (addBtn) {
      addBtn.addEventListener('click', function() {
        var used = {};
        selected.forEach(function(s) { used[s] = true; });
        var next = '';
        for (var j = 0; j < allProviders.length; j++) {
          if (!used[allProviders[j].slug]) { next = allProviders[j].slug; break; }
        }
        selected.push(next);
        updateControls();
        renderAll();
      });
    }

    renderMobile();
    checkScroll();
  }

  init();
  document.addEventListener('astro:page-load', init);
})();
</script>
