---
const providers = [
  { id: 'claude', name: 'Claude', url: 'https://claude.ai' },
  { id: 'chatgpt', name: 'ChatGPT', url: 'https://chatgpt.com' },
  { id: 'gemini', name: 'Gemini', url: 'https://gemini.google.com/app' },
  { id: 'copilot', name: 'GitHub Copilot', url: 'https://github.com/copilot' },
];
---

<div class="page-actions" data-state="closed">
  <button class="page-actions-trigger" type="button"
    aria-label="Page actions" aria-expanded="false" aria-haspopup="menu">
    <svg class="trigger-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"
      stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="8" cy="3" r="1"/>
      <circle cx="8" cy="8" r="1"/>
      <circle cx="8" cy="13" r="1"/>
    </svg>
  </button>

  <div class="page-actions-menu" role="menu" hidden>
    <!-- Copy page -->
    <button class="page-actions-item" role="menuitem" tabindex="-1" data-action="copy">
      <span class="item-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="5" y="5" width="8" height="9" rx="1"/>
          <path d="M3 11V3a1 1 0 0 1 1-1h6"/>
        </svg>
      </span>
      <span class="item-text">Copy page</span>
    </button>

    <!-- Save as PDF -->
    <button class="page-actions-item" role="menuitem" tabindex="-1" data-action="pdf">
      <span class="item-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8 2v8"/>
          <path d="M5 7l3 3 3-3"/>
          <path d="M2 11v2a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-2"/>
        </svg>
      </span>
      <span class="item-text">Save as PDF</span>
    </button>

    <div class="section-divider" role="separator"></div>
    <div class="section-label" role="presentation">Open with</div>
    <div class="section-hint" role="presentation">Copies page to clipboard, then opens</div>

    {providers.map(p => (
      <button class="page-actions-item" role="menuitem" tabindex="-1"
        data-action="provider" data-url={p.url}>
        <span class="item-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor"
            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 2h4v4"/>
            <path d="M14 2L8 8"/>
            <path d="M12 9v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h4"/>
          </svg>
        </span>
        <span class="item-text">{p.name}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .page-actions {
    position: relative;
    flex-shrink: 0;
  }

  /* Trigger: minimal icon button */
  .page-actions-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }

  .page-actions-trigger:hover {
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .page-actions-trigger:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .trigger-icon {
    flex-shrink: 0;
  }

  /* Dropdown menu */
  .page-actions-menu {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 100;
    min-width: 220px;
    margin-top: 0.25rem;
    padding: 0.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    box-shadow: var(--sl-shadow-md);
  }

  /* Section dividers and labels */
  .section-divider {
    height: 1px;
    margin: 0.25rem 0.625rem;
    background: var(--sl-color-gray-5);
  }

  .section-label {
    padding: 0.375rem 0.625rem 0.0625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    user-select: none;
  }

  .section-hint {
    padding: 0 0.625rem 0.25rem;
    font-size: 0.625rem;
    line-height: 1.3;
    color: var(--sl-color-gray-4);
    font-style: italic;
    user-select: none;
  }

  /* Menu items */
  .page-actions-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.625rem;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-white);
    font-family: inherit;
    font-size: 0.8125rem;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.1s;
  }

  .page-actions-item:hover,
  .page-actions-item:focus-visible {
    background: var(--sl-color-gray-5);
    outline: none;
  }

  .item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .item-text {
    flex: 1;
    line-height: 1;
  }

  /* Print: hide */
  @media print {
    .page-actions {
      display: none !important;
    }
  }

  /* Toast notification */
  :global(.page-actions-toast) {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    background: var(--sl-color-accent-low);
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent-high);
    font-size: 0.8125rem;
    box-shadow: var(--sl-shadow-md);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
    z-index: 1000;
  }

  :global(.page-actions-toast.visible) {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script is:inline>
  (function() {
    function init() {
      var container = document.querySelector('.page-actions');
      if (!container || container.dataset.initialized) return;
      container.dataset.initialized = 'true';

      var trigger = container.querySelector('.page-actions-trigger');
      var menu = container.querySelector('.page-actions-menu');
      var items = Array.prototype.slice.call(container.querySelectorAll('[role="menuitem"]'));

      function open() {
        container.dataset.state = 'open';
        trigger.setAttribute('aria-expanded', 'true');
        menu.removeAttribute('hidden');
        if (items[0]) items[0].focus();
      }

      function close() {
        container.dataset.state = 'closed';
        trigger.setAttribute('aria-expanded', 'false');
        menu.setAttribute('hidden', '');
      }

      trigger.addEventListener('click', function(e) {
        e.stopPropagation();
        container.dataset.state === 'open' ? close() : open();
      });

      document.addEventListener('click', function(e) {
        if (container.dataset.state === 'open' && !container.contains(e.target)) {
          close();
        }
      });

      trigger.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          e.preventDefault();
          open();
        }
      });

      container.addEventListener('keydown', function(e) {
        if (container.dataset.state !== 'open') return;
        var idx = items.indexOf(document.activeElement);
        switch (e.key) {
          case 'Escape':
            e.preventDefault();
            close();
            trigger.focus();
            break;
          case 'ArrowDown':
            e.preventDefault();
            items[(idx + 1) % items.length].focus();
            break;
          case 'ArrowUp':
            e.preventDefault();
            items[(idx - 1 + items.length) % items.length].focus();
            break;
          case 'Home':
            e.preventDefault();
            if (items[0]) items[0].focus();
            break;
          case 'End':
            e.preventDefault();
            if (items[items.length - 1]) items[items.length - 1].focus();
            break;
        }
      });

      function showToast(message) {
        var existing = document.querySelector('.page-actions-toast');
        if (existing) existing.remove();
        var toast = document.createElement('div');
        toast.className = 'page-actions-toast';
        toast.setAttribute('role', 'status');
        toast.setAttribute('aria-live', 'polite');
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(function() {
          requestAnimationFrame(function() { toast.classList.add('visible'); });
        });
        setTimeout(function() {
          toast.classList.remove('visible');
          setTimeout(function() { toast.remove(); }, 300);
        }, 2500);
      }

      function getPageContent() {
        var article = document.querySelector('.sl-markdown-content');
        if (!article) return '';
        var h1 = document.querySelector('h1');
        var title = h1 ? '# ' + h1.textContent.trim() + '\n\n' : '';
        return title + article.innerText;
      }

      function handleAction(item) {
        var action = item.dataset.action;
        switch (action) {
          case 'copy':
            navigator.clipboard.writeText(getPageContent())
              .then(function() { showToast('Copied to clipboard'); })
              .catch(function() { showToast('Failed to copy'); });
            break;
          case 'pdf':
            showToast('Opening print dialog\u2026');
            setTimeout(function() { window.print(); }, 100);
            break;
          case 'provider':
            var url = item.dataset.url;
            var pageUrl = window.location.href;
            var h1 = document.querySelector('h1');
            var title = h1 ? h1.textContent.trim() : 'Documentation';
            var content = getPageContent();
            var ctx =
              'Below is documentation from syllago (' + pageUrl + ').\n' +
              'Please help me understand and work with this content.\n\n' +
              '---\n\n' + content;
            navigator.clipboard.writeText(ctx)
              .then(function() {
                window.open(url, '_blank');
                showToast('Copied & opening ' + title + '\u2026');
              })
              .catch(function() { showToast('Failed to copy'); });
            break;
        }
        close();
      }

      items.forEach(function(item) {
        item.addEventListener('click', function() { handleAction(item); });
      });
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
