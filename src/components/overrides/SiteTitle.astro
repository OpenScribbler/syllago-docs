---
/**
 * Override Starlight's SiteTitle to use the pixel-art SVG logo.
 * Inlined so CSS can reference Starlight's data-theme attribute
 * for correct light/dark color switching.
 * Subtle lift on hover to indicate clickability.
 */
import logoSvg from '../../assets/logo.svg?raw';
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" aria-label="syllago home">
  <span class="site-logo" set:html={logoSvg} />
</a>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }
  }

  .site-logo {
    display: flex;
    height: 2.25rem;
    transition: transform 0.15s ease;
  }

  .site-logo :global(svg) {
    height: 100%;
    width: auto;
  }

  .site-title:hover .site-logo {
    transform: translateY(-2px);
  }

  .site-title:active .site-logo {
    transform: translateY(0);
  }

  /* Sync with Starlight's data-theme since inlined SVG's
     prefers-color-scheme only sees OS preference */
  :root[data-theme='light'] .site-logo :global(.sf) { fill: #047857; }
  :root[data-theme='light'] .site-logo :global(.sd) { fill: #047857; opacity: 0.4; }
  :root[data-theme='light'] .site-logo :global(.lf) { fill: #6D28D9; }
  :root[data-theme='light'] .site-logo :global(.ld) { fill: #6D28D9; opacity: 0.4; }

  :root[data-theme='dark'] .site-logo :global(.sf) { fill: #6EE7B7; }
  :root[data-theme='dark'] .site-logo :global(.sd) { fill: #6EE7B7; opacity: 0.4; }
  :root[data-theme='dark'] .site-logo :global(.lf) { fill: #C4B5FD; }
  :root[data-theme='dark'] .site-logo :global(.ld) { fill: #C4B5FD; opacity: 0.4; }
</style>
