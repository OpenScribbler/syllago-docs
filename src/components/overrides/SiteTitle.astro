---
/**
 * Override Starlight's SiteTitle to render "syll" in Flexoki cyan
 * and "ago" in the default text-accent color.
 */
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
  <span translate="no">
    <span class="logo-syll">syll</span><span class="logo-ago">ago</span>
  </span>
</a>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      font-size: var(--sl-text-h4);
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }
    span {
      overflow: hidden;
    }
  }

  .site-title {
    color: var(--sl-color-text);
  }
  .logo-syll {
    color: var(--color-cyan-300);
  }
  :root[data-theme='light'] .logo-syll {
    color: var(--color-cyan-500);
  }
</style>
