{
  "id": "pi",
  "name": "Pi",
  "slug": "pi",
  "configDir": ".pi",
  "emitPath": "{project}/AGENTS.md",
  "content": {
    "agents": {
      "supported": false,
      "symlinkSupport": false
    },
    "commands": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "filesystem",
      "installPath": "{home}/.pi/agent/prompts",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.pi/prompts"
      ]
    },
    "hooks": {
      "supported": true,
      "fileFormat": "ts",
      "installMethod": "filesystem",
      "installPath": "{home}/.pi/agent/extensions",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.pi/extensions"
      ],
      "hookEvents": [
        {
          "canonical": "after_tool_execute",
          "nativeName": "tool_result",
          "category": "tool"
        },
        {
          "canonical": "agent_stop",
          "nativeName": "agent_end",
          "category": "lifecycle"
        },
        {
          "canonical": "before_compact",
          "nativeName": "session_before_compact",
          "category": "context"
        },
        {
          "canonical": "before_prompt",
          "nativeName": "input",
          "category": "lifecycle"
        },
        {
          "canonical": "before_tool_execute",
          "nativeName": "tool_call",
          "category": "tool"
        },
        {
          "canonical": "context_update",
          "nativeName": "context",
          "category": "context"
        },
        {
          "canonical": "message_end",
          "nativeName": "message_end",
          "category": "model"
        },
        {
          "canonical": "message_start",
          "nativeName": "message_start",
          "category": "model"
        },
        {
          "canonical": "model_select",
          "nativeName": "model_select",
          "category": "model"
        },
        {
          "canonical": "session_end",
          "nativeName": "session_shutdown",
          "category": "lifecycle"
        },
        {
          "canonical": "session_start",
          "nativeName": "session_start",
          "category": "lifecycle"
        },
        {
          "canonical": "subagent_start",
          "nativeName": "before_agent_start",
          "category": "lifecycle"
        },
        {
          "canonical": "turn_end",
          "nativeName": "turn_end",
          "category": "model"
        },
        {
          "canonical": "turn_start",
          "nativeName": "turn_start",
          "category": "model"
        },
        {
          "canonical": "user_bash",
          "nativeName": "user_bash",
          "category": "tool"
        }
      ],
      "hookTypes": [
        "command"
      ],
      "configLocation": ".pi/extensions/"
    },
    "loadouts": {
      "supported": false,
      "symlinkSupport": false
    },
    "mcp": {
      "supported": false,
      "symlinkSupport": false
    },
    "rules": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "project-scope",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/AGENTS.md"
      ]
    },
    "skills": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "filesystem",
      "installPath": "{home}/.pi/agent/skills",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.pi/skills"
      ],
      "frontmatterFields": [
        "name",
        "description",
        "license",
        "compatibility",
        "metadata"
      ]
    }
  }
}
