{
  "id": "windsurf",
  "name": "Windsurf",
  "slug": "windsurf",
  "configDir": ".codeium/windsurf",
  "emitPath": "{project}/.windsurf/rules",
  "content": {
    "agents": {
      "supported": false,
      "symlinkSupport": false
    },
    "commands": {
      "supported": false,
      "symlinkSupport": false
    },
    "hooks": {
      "supported": true,
      "fileFormat": "json",
      "installMethod": "json-merge",
      "symlinkSupport": false,
      "hookEvents": [
        {
          "canonical": "agent_stop",
          "nativeName": "post_cascade_response",
          "category": "lifecycle"
        },
        {
          "canonical": "before_prompt",
          "nativeName": "pre_user_prompt",
          "category": "lifecycle"
        },
        {
          "canonical": "session_end",
          "nativeName": "session_end",
          "category": "lifecycle"
        },
        {
          "canonical": "session_start",
          "nativeName": "session_start",
          "category": "lifecycle"
        },
        {
          "canonical": "transcript_export",
          "nativeName": "post_cascade_response_with_transcript",
          "category": "output"
        },
        {
          "canonical": "worktree_create",
          "nativeName": "post_setup_worktree",
          "category": "workspace"
        }
      ],
      "hookTypes": [
        "command"
      ],
      "configLocation": ".windsurf/hooks.json"
    },
    "loadouts": {
      "supported": false,
      "symlinkSupport": false
    },
    "mcp": {
      "supported": true,
      "fileFormat": "json",
      "installMethod": "json-merge",
      "symlinkSupport": false,
      "configLocation": ".windsurf/mcp_config.json",
      "mcpTransports": [
        "stdio",
        "sse"
      ]
    },
    "rules": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "filesystem",
      "installPath": "{home}/.codeium/windsurf",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.windsurfrules",
        "{project}/.windsurf/rules"
      ],
      "frontmatterFields": [
        "trigger",
        "description",
        "globs"
      ]
    },
    "skills": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "filesystem",
      "installPath": "{home}/.codeium/windsurf/skills",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.windsurf/skills",
        "{project}/.agents/skills"
      ],
      "frontmatterFields": [
        "name",
        "description"
      ]
    }
  }
}
