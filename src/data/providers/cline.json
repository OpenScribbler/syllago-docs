{
  "id": "cline",
  "name": "Cline",
  "slug": "cline",
  "configDir": ".clinerules",
  "emitPath": "{project}/.clinerules",
  "content": {
    "agents": {
      "supported": false,
      "symlinkSupport": false
    },
    "commands": {
      "supported": false,
      "symlinkSupport": false
    },
    "hooks": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "project-scope",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.clinerules/hooks"
      ],
      "hookTypes": [
        "command"
      ],
      "configLocation": ".clinerules/hooks"
    },
    "loadouts": {
      "supported": false,
      "symlinkSupport": false
    },
    "mcp": {
      "supported": true,
      "fileFormat": "json",
      "installMethod": "json-merge",
      "symlinkSupport": false,
      "discoveryPaths": [
        "{home}/.config/Code/User/globalStorage/saoudrizwan.claude-dev/settings/cline_mcp_settings.json"
      ],
      "configLocation": "cline_mcp_settings.json",
      "mcpTransports": [
        "stdio",
        "sse",
        "streamable-http"
      ]
    },
    "rules": {
      "supported": true,
      "fileFormat": "md",
      "installMethod": "project-scope",
      "symlinkSupport": true,
      "discoveryPaths": [
        "{project}/.clinerules",
        "{home}/Documents/Cline/Rules"
      ],
      "frontmatterFields": [
        "paths"
      ]
    },
    "skills": {
      "supported": false,
      "symlinkSupport": false
    }
  }
}
